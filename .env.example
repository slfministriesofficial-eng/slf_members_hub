VITE_SUPER_ADMIN_EMAIL=admin@example.com
VITE_SUPER_ADMIN_PASSWORD=change-me
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/your-deployment-id/exec

# Firebase Cloud Messaging — all values come from Firebase Console >
# Project Settings > General > Your apps > Web app. These are public
# client identifiers (not secrets), but live in env so they never need
# a code change to rotate. The VAPID key is under Cloud Messaging >
# Web Push certificates.
VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=slf-members-hub.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=slf-members-hub
VITE_FIREBASE_MESSAGING_SENDER_ID=710577463008
VITE_FIREBASE_APP_ID=your-web-app-id
VITE_FIREBASE_VAPID_KEY=BNRG65Bw7Un-z2P4QMy3jVtagjr-ZF38fONEyv-rq0eoe2Za5MZlC9rwC44PfhaUwXQwXcW0R7PRAuv-jktowFs
